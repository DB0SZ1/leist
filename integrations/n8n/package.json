{
  "name": "n8n-nodes-listintel",
  "version": "1.0.0",
  "description": "List Intel n8n Community Node for Email Deliverability & Intelligence",
  "main": "dist/index.js",
  "license": "MIT",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ListIntelApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ListIntel/ListIntel.node.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "lint": "eslint \"nodes/**/*.ts\" \"credentials/**/*.ts\"",
    "lintfix": "eslint \"nodes/**/*.ts\" \"credentials/**/*.ts\" --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "n8n-core": "*",
    "typescript": "^4.8.4",
    "n8n-workflow": "*"
  }
}
